# Craig Pricing Service — environment variables
# Copy this file to .env and fill in your values.

# --- DeepSeek (LLM) ---
# Get your API key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=PLACEHOLDER_PASTE_YOUR_KEY_HERE

# Model name. Default is deepseek-chat. Other options: deepseek-reasoner
DEEPSEEK_MODEL=deepseek-chat

# --- Database ---
# Default: SQLite file at ./craig.db
# On cloud-synced folders (iCloud, Dropbox, etc.) SQLite can hit I/O errors.
# If that happens, point this to a local-only path, e.g. /tmp/craig.db or ~/craig.db
CRAIG_DB_PATH=./craig.db

# Or use a full database URL (Postgres in production):
# CRAIG_DATABASE_URL=postgresql://user:pass@host:5432/craig

# --- Strategos Dashboard integration ---
# Shared secret used to verify JWTs minted by the Strategos Dashboard when it
# calls /admin/api/*. Must match STRATEGOS_JWT_SECRET in the dashboard env.
# Generate: openssl rand -hex 32
STRATEGOS_JWT_SECRET=
